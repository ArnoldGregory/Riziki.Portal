@using System.Security.Claims
@{
    var currentAvatar = User.FindFirstValue("avatar") ?? "user-default.svg";
}

@section PageStyles {
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <style>
        .profile-photo-wrap { text-align: center; margin-bottom: 24px; }
        .profile-photo-wrap img {
            width: 110px; height: 110px; border-radius: 50%;
            object-fit: cover; border: 4px solid #348fe2;
            cursor: pointer; transition: opacity .2s;
        }
        .profile-photo-wrap img:hover { opacity: .8; }
        .profile-photo-wrap .photo-hint { font-size: 12px; color: #888; margin-top: 6px; }
        #photoFileInput { display: none; }
    </style>
}

<h1 class="page-header"><i class="fa fa-user"></i> My Profile</h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">My Profile</h4>
    </div>
    <div class="panel-body">

        <!-- Profile Photo -->
        <div class="row">
            <div class="col-md-12">
                <div class="profile-photo-wrap">
                    <img id="profilePhotoPreview"
                         src="/assets/static/img/profile-pics/@currentAvatar"
                         onerror="this.onerror=null;this.src='/assets/static/img/profile-pics/user-default.svg';"
                         title="Click to change photo" />
                    <input type="file" id="photoFileInput" accept=".jpg,.jpeg,.png" />
                    <div class="photo-hint"><i class="fa fa-camera"></i> Click photo to change &nbsp;|&nbsp; JPG or PNG, max 3MB</div>
                    <div id="photo-upload-error" class="alert alert-danger m-t-5" style="display:none;"></div>
                </div>
            </div>
        </div>

        <div class="row">
            <div class="col-md-8 col-md-offset-2">

                <div id="profile-loading" class="text-center p-20">
                    <i class="fa fa-spinner fa-spin fa-2x"></i><br/><small>Loading profile...</small>
                </div>

                <div id="profile-form" style="display:none;">
                    <!-- Read-only fields -->
                    <fieldset>
                        <legend>Personal Information</legend>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>First Name</label>
                                    <input type="text" class="form-control" id="p_first_name" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Last Name</label>
                                    <input type="text" class="form-control" id="p_last_name" readonly />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>ID Number</label>
                                    <input type="text" class="form-control" id="p_id_number" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Staff Number</label>
                                    <input type="text" class="form-control" id="p_staff_number" readonly />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Department</label>
                                    <input type="text" class="form-control" id="p_department" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Job Title</label>
                                    <input type="text" class="form-control" id="p_job_title" readonly />
                                </div>
                            </div>
                        </div>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Employment Type</label>
                                    <input type="text" class="form-control" id="p_emp_type" readonly />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Hire Date</label>
                                    <input type="text" class="form-control" id="p_hire_date" readonly />
                                </div>
                            </div>
                        </div>
                    </fieldset>

                    <fieldset class="m-t-20">
                        <legend>Contact Information <small class="text-muted">(editable)</small></legend>
                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Email <span class="text-danger">*</span></label>
                                    <input type="email" class="form-control" id="p_email" />
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label>Mobile <span class="text-danger">*</span></label>
                                    <input type="text" class="form-control" id="p_mobile" />
                                </div>
                            </div>
                        </div>
                        <div id="profile-error" class="alert alert-danger" style="display:none;"></div>
                        <div class="text-right">
                            <a href="#" class="btn btn-success" id="btnSaveProfile"><i class="fa fa-save"></i> Save Contact Info</a>
                        </div>
                    </fieldset>
                </div>
            </div>
        </div>

    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/ss-myprofile.js?v=2"></script>
}
