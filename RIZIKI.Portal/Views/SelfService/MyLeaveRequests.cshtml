@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-calendar"></i> My Leave Requests</h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadMyLeave();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">My Leave Requests</h4>
    </div>
    <div class="panel-body">

        <div class="row m-b-10">
            <div class="col-md-12">
                <a href="#" class="btn btn-sm btn-success" data-toggle="modal" data-target="#apply-leave-modal">
                    <i class="fa fa-plus"></i> Apply for Leave
                </a>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <table id="myLeaveTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>Leave Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Days</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Applied On</th>
                            <th>Rejection Reason</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- APPLY LEAVE MODAL -->
<div class="modal fade" id="apply-leave-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><i class="fa fa-times-circle"></i></button>
                <h4 class="modal-title"><i class="fa fa-calendar-plus-o"></i> Apply for Leave</h4>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Leave Type <span class="text-danger">*</span></label>
                    <select id="apply_leave_type" class="form-control">
                        <option value="">— Select Leave Type —</option>
                    </select>
                </div>
                <div class="form-group">
                    <label>Half Day?</label>
                    <div>
                        <label class="radio-inline">
                            <input type="radio" name="apply_half_day" id="apply_half_day_no" value="no" checked /> No
                        </label>
                        <label class="radio-inline">
                            <input type="radio" name="apply_half_day" id="apply_half_day_yes" value="yes" /> Yes
                        </label>
                    </div>
                </div>
                <div id="apply_half_day_period_row" class="form-group" style="display:none;">
                    <label>Period <span class="text-danger">*</span></label>
                    <div>
                        <label class="radio-inline">
                            <input type="radio" name="apply_half_period" value="AM" checked /> Morning (AM)
                        </label>
                        <label class="radio-inline">
                            <input type="radio" name="apply_half_period" value="PM" /> Afternoon (PM)
                        </label>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>From Date <span class="text-danger">*</span></label>
                            <input id="apply_start_date" type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6" id="apply_end_date_col">
                        <div class="form-group">
                            <label>To Date <span class="text-danger">*</span></label>
                            <input id="apply_end_date" type="date" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Reason</label>
                    <textarea id="apply_reason" rows="3" class="form-control" placeholder="Optional reason for leave"></textarea>
                </div>
                <div id="apply-leave-error" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-white btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Cancel</a>
                <a href="#" class="btn btn-success btn-sm" id="btnSubmitLeave"><i class="fa fa-paper-plane"></i> Submit</a>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/ss-myleave.js?v=2"></script>
}
