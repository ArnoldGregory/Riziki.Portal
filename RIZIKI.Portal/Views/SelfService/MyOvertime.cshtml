@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-clock-o"></i> My Overtime</h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadMyOvertime();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">My Overtime Requests</h4>
    </div>
    <div class="panel-body">

        <div class="row m-b-10">
            <div class="col-md-12">
                <a href="#" class="btn btn-sm btn-success" data-toggle="modal" data-target="#submit-ot-modal">
                    <i class="fa fa-plus"></i> Submit Overtime
                </a>
            </div>
        </div>

        <div class="row">
            <div class="col-md-12">
                <table id="myOtTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>Date</th>
                            <th>Start</th>
                            <th>End</th>
                            <th>Hours</th>
                            <th>Rate (KES)</th>
                            <th>Amount (KES)</th>
                            <th>Reason</th>
                            <th>Status</th>
                            <th>Submitted On</th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- SUBMIT OVERTIME MODAL -->
<div class="modal fade" id="submit-ot-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><i class="fa fa-times-circle"></i></button>
                <h4 class="modal-title"><i class="fa fa-clock-o"></i> Submit Overtime Claim</h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-md-12">
                        <div class="form-group">
                            <label>Date <span class="text-danger">*</span></label>
                            <input id="ot_date" type="date" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Start Time <span class="text-danger">*</span></label>
                            <input id="ot_start" type="time" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>End Time <span class="text-danger">*</span></label>
                            <input id="ot_end" type="time" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Hourly Rate (KES) <span class="text-danger">*</span></label>
                    <input id="ot_rate" type="number" step="0.01" min="0" class="form-control" placeholder="e.g. 500" />
                </div>
                <div class="form-group">
                    <label>Reason</label>
                    <textarea id="ot_reason" rows="2" class="form-control" placeholder="Brief description of overtime work"></textarea>
                </div>
                <div id="ot-submit-error" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-white btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Cancel</a>
                <a href="#" class="btn btn-success btn-sm" id="btnSubmitOt"><i class="fa fa-paper-plane"></i> Submit</a>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/ss-myovertime.js?v=1"></script>
}
