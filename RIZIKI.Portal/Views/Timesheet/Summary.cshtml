@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-clock-o"></i> Timesheet Summary <small>All Employees</small></h1>

<div class="panel panel-inverse">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadSummary();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">Hours Worked by Employee</h4>
    </div>
    <div class="panel-body">

        <!-- Date range filter -->
        <div class="row m-b-15">
            <div class="col-md-3">
                <label class="control-label">From</label>
                <input type="date" id="txtFrom" class="form-control input-sm" />
            </div>
            <div class="col-md-3">
                <label class="control-label">To</label>
                <input type="date" id="txtTo" class="form-control input-sm" />
            </div>
            <div class="col-md-2">
                <label class="control-label">&nbsp;</label>
                <div>
                    <a href="javascript:LoadSummary();" class="btn btn-sm btn-primary">
                        <i class="fa fa-search"></i> Filter
                    </a>
                </div>
            </div>
        </div>

        <table id="summaryTable" class="table table-striped table-hover table-bordered table-condensed">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Employee</th>
                    <th>Entries</th>
                    <th>Days Active</th>
                    <th>Total Hours</th>
                </tr>
            </thead>
        </table>

    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.js"></script>
    <script src="~/assets/static/js/timesheet-summary.js"></script>
}
