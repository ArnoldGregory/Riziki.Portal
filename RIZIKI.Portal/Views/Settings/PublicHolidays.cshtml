@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-calendar"></i> Public Holidays</h1>

<div class="panel panel-inverse">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadHolidays();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
        </div>
        <h4 class="panel-title">Manage Public Holidays</h4>
    </div>
    <div class="panel-body">
        <div class="row m-b-10">
            <div class="col-md-3">
                <input type="text" id="txtHolidayName" class="form-control" placeholder="Holiday Name e.g. Jamhuri Day" />
            </div>
            <div class="col-md-2">
                <input type="date" id="txtHolidayDate" class="form-control" />
            </div>
            <div class="col-md-2">
                <a href="javascript:AddHoliday(this);" class="btn btn-primary btn-block"><i class="fa fa-plus"></i> Add Holiday</a>
            </div>
        </div>
        <table id="holidaysTable" class="table table-striped table-hover table-bordered table-condensed">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Holiday Name</th>
                    <th>Date</th>
                    <th>Day</th>
                    <th></th>
                </tr>
            </thead>
        </table>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/js/settings-holidays.js"></script>
}
