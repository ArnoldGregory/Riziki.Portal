@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-wrench"></i> Settings <small>System Parameters</small></h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadParameters();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">Parameters List</h4>
    </div>
    <div class="panel-body">
        <div class="row m-b-10">
            <div class="col-md-12">
                <a href="#" class="btn btn-sm btn-success" data-toggle="modal" data-target="#param-modal">
                    <i class="fa fa-plus"></i> Add Parameter
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <table id="paramsTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Key</th>
                            <th>Value</th>
                            <th>Remarks</th>
                            <th>Created On</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ADD / EDIT PARAMETER MODAL -->
<div class="modal fade" id="param-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><i class="fa fa-times-circle"></i></button>
                <h4 class="modal-title" id="paramModalTitle"><i class="fa fa-wrench"></i> Add Parameter</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="param_id" value="0" />
                <div class="form-group">
                    <label>Key <span class="text-danger">*</span></label>
                    <input id="param_key" type="text" class="form-control" placeholder="e.g. COMPANY_NAME" />
                </div>
                <div class="form-group">
                    <label>Value <span class="text-danger">*</span></label>
                    <textarea id="param_value" rows="3" class="form-control"></textarea>
                </div>
                <div class="form-group">
                    <label>Remarks</label>
                    <textarea id="param_comments" rows="2" class="form-control"></textarea>
                </div>
                <div id="param-error" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-white btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Cancel</a>
                <a href="#" class="btn btn-success btn-sm" id="btnSaveParam"><i class="fa fa-save"></i> Save</a>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/settings-parameters.js"></script>
}
