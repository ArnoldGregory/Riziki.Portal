@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-building"></i> Settings <small>Bank Branches</small></h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadBranches();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">Bank Branches</h4>
    </div>
    <div class="panel-body">
        <!-- Filter by bank -->
        <div class="row m-b-10">
            <div class="col-md-4">
                <div class="form-group">
                    <label><strong>Filter by Bank</strong></label>
                    <select id="filter_bank_id" class="form-control">
                        <option value="0">— All Banks —</option>
                    </select>
                </div>
            </div>
            <div class="col-md-8" style="padding-top:25px;">
                <a href="#" class="btn btn-sm btn-success" data-toggle="modal" data-target="#branch-modal">
                    <i class="fa fa-plus"></i> Add Branch
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <table id="branchesTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Bank</th>
                            <th>Branch Code</th>
                            <th>Branch Name</th>
                            <th>Location</th>
                            <th>Created On</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ADD / EDIT BRANCH MODAL -->
<div class="modal fade" id="branch-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><i class="fa fa-times-circle"></i></button>
                <h4 class="modal-title" id="branchModalTitle"><i class="fa fa-building"></i> Add Branch</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="branch_id" value="0" />
                <div class="form-group">
                    <label>Bank <span class="text-danger">*</span></label>
                    <select id="branch_bank_id" class="form-control">
                        <option value="">— Select Bank —</option>
                    </select>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Branch Code <span class="text-danger">*</span></label>
                            <input id="branch_code" type="text" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-group">
                            <label>Branch Name <span class="text-danger">*</span></label>
                            <input id="branch_name" type="text" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="form-group">
                    <label>Location</label>
                    <input id="branch_location" type="text" class="form-control" />
                </div>
                <div id="branch-error" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-white btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Cancel</a>
                <a href="#" class="btn btn-success btn-sm" id="btnSaveBranch"><i class="fa fa-save"></i> Save</a>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/settings-bank-branches.js"></script>
}
