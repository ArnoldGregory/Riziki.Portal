@{
    ViewData["Title"] = "My Dashboard";
    ViewBag.MenuLayout = "Side";
}

<h1 class="page-header">My Dashboard</h1>

<!-- ── Stat cards ─────────────────────────────────────────────── -->
<div class="row">
    <div class="col-md-3 col-sm-6">
        <div class="widget widget-stats bg-green">
            <div class="stats-icon"><i class="fa fa-calendar"></i></div>
            <div class="stats-info"><h4>LEAVE BALANCE</h4><p id="statBalance"><i class="fa fa-spinner fa-spin"></i></p></div>
            <div class="stats-link"><a href="/SelfService/MyBalance">View Detail <i class="fa fa-arrow-alt-circle-right"></i></a></div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="widget widget-stats bg-blue">
            <div class="stats-icon"><i class="fa fa-clock"></i></div>
            <div class="stats-info"><h4>PENDING LEAVE</h4><p id="statMyLeave"><i class="fa fa-spinner fa-spin"></i></p></div>
            <div class="stats-link"><a href="/SelfService/MyLeaveRequests">View Detail <i class="fa fa-arrow-alt-circle-right"></i></a></div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="widget widget-stats bg-orange">
            <div class="stats-icon"><i class="fa fa-money-bill"></i></div>
            <div class="stats-info"><h4>MY ADVANCES</h4><p id="statMyAdvances"><i class="fa fa-spinner fa-spin"></i></p></div>
            <div class="stats-link"><a href="/SelfService/MyAdvances">View Detail <i class="fa fa-arrow-alt-circle-right"></i></a></div>
        </div>
    </div>
    <div class="col-md-3 col-sm-6">
        <div class="widget widget-stats bg-purple">
            <div class="stats-icon"><i class="fa fa-file-invoice"></i></div>
            <div class="stats-info"><h4>LATEST PAYSLIP</h4><p id="statMyPayslip"><i class="fa fa-spinner fa-spin"></i></p></div>
            <div class="stats-link"><a href="/SelfService/MyPayslips">View Detail <i class="fa fa-arrow-alt-circle-right"></i></a></div>
        </div>
    </div>
</div>

<!-- ── Row 2: Payslip trend (8) + Leave balance (4) ──────────── -->
<div class="row m-t-20">
    <div class="col-md-8">
        <div class="panel panel-inverse">
            <div class="panel-heading">
                <h4 class="panel-title"><i class="fa fa-chart-bar m-r-5"></i>My Net Pay <small class="text-muted">— last 6 payslips</small></h4>
            </div>
            <div class="panel-body">
                <div id="chartPayslipTrend" style="min-height:260px;"></div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="panel panel-inverse">
            <div class="panel-heading">
                <h4 class="panel-title"><i class="fa fa-chart-pie m-r-5"></i>Leave Balance</h4>
            </div>
            <div class="panel-body">
                <div id="chartLeaveBalance" style="min-height:260px;"></div>
            </div>
        </div>
    </div>
</div>

<!-- ── HOD Dept Approvals (hidden; shown by JS if is_hod=true) ──── -->
<div class="row m-t-20" id="hodApprovalsRow" style="display:none;">
    <div class="col-md-12">
        <div class="panel panel-inverse">
            <div class="panel-heading">
                <h4 class="panel-title" style="color:#fff;">
                    <i class="fa fa-user-check m-r-5"></i> Department Leave Approvals
                    <small style="color:#adb5bd;">— pending from your team</small>
                </h4>
            </div>
            <div class="panel-body">
                <table id="hodLeaveTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>Employee</th>
                            <th>Leave Type</th>
                            <th>From</th>
                            <th>To</th>
                            <th>Days</th>
                            <th>Reason</th>
                            <th>Applied On</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody id="hodLeaveBody">
                        <tr><td colspan="8" class="text-muted text-center">Loading...</td></tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/apexcharts/dist/apexcharts.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <script src="~/assets/static/js/empdash.js"></script>
}
