@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <style>
        @@media print {
            .no-print { display: none !important; }
            .panel { border: none !important; box-shadow: none !important; }
            body { background: #fff !important; }
        }
    </style>
}

<h1 class="page-header no-print"><i class="fa fa-users"></i> Employee Report</h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading no-print">
        <div class="panel-heading-btn">
            <a href="javascript:LoadEmpReport();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">All Employees Report</h4>
    </div>
    <div class="panel-body">

        <div class="row m-b-10 no-print">
            <div class="col-md-12">
                <a href="#" class="btn btn-sm btn-default" onclick="window.print(); return false;">
                    <i class="fa fa-print"></i> Print
                </a>
            </div>
        </div>

        <div class="text-center m-b-15">
            <h3>Employee Report</h3>
            <p class="text-muted" id="emp_rpt_date"></p>
        </div>

        <div class="table-responsive">
            <table id="empRptTable" class="table table-striped table-hover table-bordered table-condensed">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Full Name</th>
                        <th>Staff #</th>
                        <th>ID Number</th>
                        <th>Email</th>
                        <th>Mobile</th>
                        <th>Department</th>
                        <th>Job Title</th>
                        <th>Employment Type</th>
                        <th>Hire Date</th>
                    </tr>
                </thead>
            </table>
        </div>

    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/js/reports-employees.js"></script>
}
