@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-file-text"></i> P9 Annual Tax Summary</h1>

<div class="panel panel-inverse">
    <div class="panel-heading"><h4 class="panel-title">Generate P9 Form</h4></div>
    <div class="panel-body">
        <div class="row m-b-15">
            <div class="col-md-4">
                <label>Employee</label>
                <select id="selEmployee" class="form-control"><option value="">-- Select Employee --</option></select>
            </div>
            <div class="col-md-2">
                <label>Year</label>
                <select id="selYear" class="form-control"></select>
            </div>
            <div class="col-md-2">
                <label>&nbsp;</label>
                <a href="javascript:LoadP9(this);" class="btn btn-primary btn-block"><i class="fa fa-search"></i> Load</a>
            </div>
            <div class="col-md-2">
                <label>&nbsp;</label>
                <a href="javascript:PrintP9();" class="btn btn-default btn-block"><i class="fa fa-print"></i> Print</a>
            </div>
        </div>

        <div id="p9Report" style="display:none;">
            <div class="well well-sm m-b-10">
                <strong>Employee:</strong> <span id="lblEmpName"></span> &nbsp;|&nbsp;
                <strong>KRA PIN:</strong> <span id="lblKraPin"></span> &nbsp;|&nbsp;
                <strong>Employer PIN:</strong> <span id="lblEmployerPin"></span> &nbsp;|&nbsp;
                <strong>Year:</strong> <span id="lblYear"></span>
            </div>
            <table id="p9Table" class="table table-striped table-bordered table-condensed">
                <thead>
                    <tr>
                        <th>Month</th>
                        <th>Basic (KES)</th>
                        <th>Allowances</th>
                        <th>Gross Pay</th>
                        <th>NSSF</th>
                        <th>SHIF</th>
                        <th>Housing Levy</th>
                        <th>Taxable Income</th>
                        <th>PAYE</th>
                        <th>Personal Relief</th>
                        <th>Net PAYE</th>
                    </tr>
                </thead>
                <tfoot>
                    <tr class="info">
                        <th>TOTALS</th>
                        <th id="tBasic"></th><th id="tAllowances"></th><th id="tGross"></th>
                        <th id="tNssf"></th><th id="tShif"></th><th id="tHousing"></th>
                        <th id="tTaxable"></th><th id="tPaye"></th><th id="tRelief"></th>
                        <th id="tNetPaye"></th>
                    </tr>
                </tfoot>
            </table>
        </div>
        <div id="p9Empty" class="text-center text-muted" style="padding:30px;">
            Select an employee and year, then click Load.
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/js/reports-p9.js"></script>
}
