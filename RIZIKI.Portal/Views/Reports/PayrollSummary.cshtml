@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
    <style>
        @@media print {
            .no-print { display: none !important; }
            .panel { border: none !important; box-shadow: none !important; }
            body { background: #fff !important; }
        }
    </style>
}

<h1 class="page-header no-print"><i class="fa fa-bar-chart"></i> Payroll Summary Report</h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading no-print">
        <div class="panel-heading-btn">
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">Payroll Summary Report</h4>
    </div>
    <div class="panel-body">

        <!-- Period selector -->
        <div class="row m-b-15 no-print">
            <div class="col-md-5">
                <div class="form-group">
                    <label><strong>Select Payroll Period</strong></label>
                    <select id="rpt_period_sel" class="form-control">
                        <option value="">— Select Period —</option>
                    </select>
                </div>
            </div>
            <div class="col-md-3">
                <div class="form-group">
                    <label>&nbsp;</label>
                    <div>
                        <a href="#" class="btn btn-primary" id="btnLoadReport"><i class="fa fa-search"></i> View Report</a>
                        <a href="#" class="btn btn-default" id="btnPrintReport" style="display:none;"><i class="fa fa-print"></i> Print</a>
                        <a href="#" class="btn btn-info" id="btnExportReport" style="display:none;"><i class="fa fa-download"></i> Bank File</a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Report area -->
        <div id="report-area" style="display:none;">

            <!-- Header (printed) -->
            <div class="text-center m-b-15">
                <h3 id="rpt_title">Payroll Summary Report</h3>
                <p id="rpt_subtitle" class="text-muted"></p>
            </div>

            <!-- KPI summary row -->
            <div class="row m-b-15">
                <div class="col-md-3">
                    <div class="widget widget-stats bg-blue">
                        <div class="stats-icon"><i class="fa fa-users"></i></div>
                        <div class="stats-info"><h4>EMPLOYEES</h4><p id="rpt_count">0</p></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="widget widget-stats bg-green">
                        <div class="stats-icon"><i class="fa fa-money"></i></div>
                        <div class="stats-info"><h4>TOTAL GROSS</h4><p id="rpt_gross">0.00</p></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="widget widget-stats bg-orange">
                        <div class="stats-icon"><i class="fa fa-minus-circle"></i></div>
                        <div class="stats-info"><h4>TOTAL PAYE</h4><p id="rpt_paye">0.00</p></div>
                    </div>
                </div>
                <div class="col-md-3">
                    <div class="widget widget-stats bg-purple">
                        <div class="stats-icon"><i class="fa fa-check-circle"></i></div>
                        <div class="stats-info"><h4>TOTAL NET PAY</h4><p id="rpt_net">0.00</p></div>
                    </div>
                </div>
            </div>

            <!-- Detail table -->
            <div class="table-responsive">
                <table id="rptTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>Employee Name</th>
                            <th>Staff #</th>
                            <th>Basic (KES)</th>
                            <th>Gross (KES)</th>
                            <th>PAYE</th>
                            <th>NSSF</th>
                            <th>SHIF</th>
                            <th>Housing Levy</th>
                            <th>Advance</th>
                            <th>Total Ded.</th>
                            <th>Net Pay (KES)</th>
                        </tr>
                    </thead>
                    <tfoot>
                        <tr class="success">
                            <th colspan="4">TOTALS</th>
                            <th id="ft2_gross"></th>
                            <th id="ft2_paye"></th>
                            <th id="ft2_nssf"></th>
                            <th id="ft2_shif"></th>
                            <th id="ft2_housing"></th>
                            <th id="ft2_advance"></th>
                            <th id="ft2_totalded"></th>
                            <th id="ft2_net"></th>
                        </tr>
                    </tfoot>
                </table>
            </div>
        </div>

    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/reports-payroll.js"></script>
}
