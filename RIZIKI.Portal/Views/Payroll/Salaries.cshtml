@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-money"></i> Salary Structures <small>Manage</small></h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadSalaries();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">Employee Salary Structures</h4>
    </div>
    <div class="panel-body">

        <div class="row">
            <div class="col-md-12">
                <table id="salaryTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>Full Name</th>
                            <th>Staff #</th>
                            <th>Department</th>
                            <th>Job Title</th>
                            <th>Emp. Type</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>

    </div>
</div>

<!-- SET / EDIT SALARY MODAL -->
<div class="modal fade" id="salary-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><i class="fa fa-times-circle"></i></button>
                <h4 class="modal-title"><i class="fa fa-money"></i> Set Salary Structure — <span id="sal_emp_name"></span></h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="sal_employee_id" />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Basic Salary (KES) <span class="text-danger">*</span></label>
                            <input id="sal_basic" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>House Allowance (KES)</label>
                            <input id="sal_house" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Transport Allowance (KES)</label>
                            <input id="sal_transport" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Medical Allowance (KES)</label>
                            <input id="sal_medical" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                        </div>
                    </div>
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Other Allowance (KES)</label>
                            <input id="sal_other" type="number" step="0.01" min="0" class="form-control" placeholder="0.00" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-4">
                        <div class="form-group">
                            <label>Effective Date</label>
                            <input id="sal_effective" type="date" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-8">
                        <div class="form-group">
                            <label>Gross Pay Preview (KES)</label>
                            <input id="sal_gross_preview" type="text" class="form-control" readonly style="background:#f5f5f5;font-weight:bold;" />
                        </div>
                    </div>
                </div>
                <div id="sal-error" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-white btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Cancel</a>
                <a href="#" class="btn btn-success btn-sm" id="btnSaveSalary"><i class="fa fa-save"></i> Save Structure</a>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/payroll-salaries.js"></script>
}
