@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/DataTables/extensions/Responsive/css/responsive.bootstrap.min.css" rel="stylesheet" />
    <link href="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-users"></i> Portal Users <small>Management</small></h1>

<div class="panel panel-inverse" id="main_panel">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadUsers();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
            <a href="@Url.Action("Index","Dashboard")" class="btn btn-xs btn-icon btn-circle btn-danger" data-click="panel-remove"><i class="fa fa-times"></i></a>
        </div>
        <h4 class="panel-title">All Users</h4>
    </div>
    <div class="panel-body">
        <div class="row m-b-10">
            <div class="col-md-12">
                <a href="#" class="btn btn-sm btn-success" data-toggle="modal" data-target="#add-user-modal">
                    <i class="fa fa-plus"></i> Add User
                </a>
            </div>
        </div>
        <div class="row">
            <div class="col-md-12">
                <table id="usersTable" class="table table-striped table-hover table-bordered table-condensed">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Role</th>
                            <th>Approved</th>
                            <th>Locked</th>
                            <th></th>
                        </tr>
                    </thead>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ADD / EDIT USER MODAL -->
<div class="modal fade" id="add-user-modal" tabindex="-1" role="dialog" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <button type="button" class="close" data-dismiss="modal"><i class="fa fa-times-circle"></i></button>
                <h4 class="modal-title" id="userModalTitle"><i class="fa fa-user-plus"></i> Add User</h4>
            </div>
            <div class="modal-body">
                <input type="hidden" id="usr_id" value="0" />
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>First Name <span class="text-danger">*</span></label>
                            <input id="usr_first_name" type="text" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Last Name <span class="text-danger">*</span></label>
                            <input id="usr_last_name" type="text" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Email <span class="text-danger">*</span></label>
                            <input id="usr_email" type="email" class="form-control" />
                        </div>
                    </div>
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Mobile</label>
                            <input id="usr_mobile" type="text" class="form-control" />
                        </div>
                    </div>
                </div>
                <div class="row">
                    <div class="col-md-6">
                        <div class="form-group">
                            <label>Role <span class="text-danger">*</span></label>
                            <select id="usr_role_id" class="form-control">
                                <option value="">— Select Role —</option>
                            </select>
                        </div>
                    </div>
                    <div class="col-md-6" id="pwd-group">
                        <div class="form-group">
                            <label>Password <span class="text-danger">*</span></label>
                            <input id="usr_password" type="password" class="form-control" />
                        </div>
                    </div>
                </div>

                <!-- HR EMPLOYEE FIELDS — shown only when role is HR -->
                <div id="hr-employee-fields" style="display:none;">
                    <hr />
                    <p class="text-info m-b-10"><i class="fa fa-info-circle"></i> HR users are also employees. Fill in their employment details:</p>
                    <div class="row">
                        <div class="col-md-5">
                            <div class="form-group">
                                <label>Staff Number</label>
                                <input id="usr_staff_number" type="text" class="form-control" placeholder="Auto-generated" />
                            </div>
                        </div>
                        <div class="col-md-7">
                            <div class="form-group">
                                <label>Job Title</label>
                                <input id="usr_job_title" type="text" class="form-control" placeholder="HR Manager" />
                            </div>
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Department</label>
                                <select id="usr_dept_id" class="form-control">
                                    <option value="0">— None —</option>
                                </select>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="form-group">
                                <label>Hire Date <span class="text-danger">*</span></label>
                                <input id="usr_hire_date" type="date" class="form-control" />
                            </div>
                        </div>
                    </div>
                    <div class="form-group">
                        <label>Basic Salary (KES) <span class="text-danger">*</span></label>
                        <input id="usr_salary" type="number" class="form-control" placeholder="e.g. 80000" min="0" step="0.01" />
                    </div>
                </div>

                <div id="user-error" class="alert alert-danger" style="display:none;"></div>
            </div>
            <div class="modal-footer">
                <a href="#" class="btn btn-white btn-sm" data-dismiss="modal"><i class="fa fa-times"></i> Cancel</a>
                <a href="#" class="btn btn-success btn-sm" id="btnSaveUser"><i class="fa fa-save"></i> Save</a>
            </div>
        </div>
    </div>
</div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/plugins/DataTables/extensions/Responsive/js/dataTables.responsive.min.js"></script>
    <script src="~/assets/static/plugins/bootstrap-sweetalert2/sweetalert2.all.min.js"></script>
    <script src="~/assets/static/js/ac-users.js"></script>
}
