@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-star"></i> My Appraisal Goals</h1>

<div class="panel panel-inverse">
    <div class="panel-heading">
        <div class="panel-heading-btn">
            <a href="javascript:LoadMyGoals();" class="btn btn-xs btn-icon btn-circle btn-success"><i class="fa fa-repeat"></i></a>
        </div>
        <h4 class="panel-title">My Goals</h4>
    </div>
    <div class="panel-body">
        <div class="form-group col-md-4 p-l-0">
            <label>Appraisal Cycle</label>
            <select id="selCycle" class="form-control" onchange="LoadMyGoals()"><option value="">-- Select Cycle --</option></select>
        </div>
        <div class="clearfix"></div>
        <table id="goalsTable" class="table table-striped table-hover table-bordered table-condensed">
            <thead>
                <tr>
                    <th>Goal</th>
                    <th>Weight %</th>
                    <th>Self Rating</th>
                    <th>Manager Rating</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
        </table>
    </div>
</div>

<!-- Self-Rate Modal -->
<div class="modal fade" id="selfRateModal"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h4 class="modal-title">Submit Self-Assessment</h4></div>
    <div class="modal-body">
        <input type="hidden" id="hAppraisalId" />
        <p id="lblGoalTitle" class="text-bold"></p>
        <div class="form-group">
            <label>Self Rating (1–5)</label>
            <input type="number" id="txtSelfRating" class="form-control" min="1" max="5" step="0.5" placeholder="1 = Poor, 5 = Excellent" />
        </div>
        <div class="form-group">
            <label>Comments</label>
            <textarea id="txtSelfComments" class="form-control" rows="3" placeholder="Describe your performance..."></textarea>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn btn-default" data-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="SubmitSelf(this)">Submit</button>
    </div>
</div></div></div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/js/appraisal-goals.js"></script>
}
