@section PageStyles {
    <link href="~/assets/static/plugins/DataTables/media/css/dataTables.bootstrap.min.css" rel="stylesheet" />
}

<h1 class="page-header"><i class="fa fa-star-half-o"></i> Appraisal Review</h1>

<div class="panel panel-inverse">
    <div class="panel-heading"><h4 class="panel-title">Add & Rate Goals</h4></div>
    <div class="panel-body">
        <input type="hidden" id="hCycleId" value="@ViewBag.CycleId" />

        <div class="row m-b-10">
            <div class="col-md-3">
                <label>Employee</label>
                <select id="selEmployee" class="form-control"><option value="">-- Select --</option></select>
            </div>
            <div class="col-md-3">
                <label>Goal Title</label>
                <input type="text" id="txtGoalTitle" class="form-control" placeholder="e.g. Achieve sales target" />
            </div>
            <div class="col-md-2">
                <label>Description</label>
                <input type="text" id="txtGoalDesc" class="form-control" placeholder="(optional)" />
            </div>
            <div class="col-md-1">
                <label>Weight %</label>
                <input type="number" id="txtWeight" class="form-control" value="0" min="0" max="100" />
            </div>
            <div class="col-md-2">
                <label>&nbsp;</label>
                <a href="javascript:AddGoal(this);" class="btn btn-primary btn-block"><i class="fa fa-plus"></i> Add Goal</a>
            </div>
            <div class="col-md-1">
                <label>&nbsp;</label>
                <a href="javascript:LoadGoals();" class="btn btn-default btn-block"><i class="fa fa-search"></i></a>
            </div>
        </div>

        <table id="goalsTable" class="table table-striped table-hover table-bordered table-condensed">
            <thead>
                <tr>
                    <th>Employee</th>
                    <th>Goal</th>
                    <th>Weight%</th>
                    <th>Self Rating</th>
                    <th>Self Comments</th>
                    <th>Manager Rating</th>
                    <th>Status</th>
                    <th></th>
                </tr>
            </thead>
        </table>
    </div>
</div>

<!-- Manager Rate Modal -->
<div class="modal fade" id="rateModal"><div class="modal-dialog"><div class="modal-content">
    <div class="modal-header"><h4 class="modal-title">Rate Goal</h4></div>
    <div class="modal-body">
        <input type="hidden" id="hAppraisalId" />
        <div class="form-group">
            <label>Manager Rating (1–5)</label>
            <input type="number" id="txtManagerRating" class="form-control" min="1" max="5" step="0.5" />
        </div>
        <div class="form-group">
            <label>Comments</label>
            <textarea id="txtManagerComments" class="form-control" rows="3"></textarea>
        </div>
    </div>
    <div class="modal-footer">
        <button class="btn btn-default" data-dismiss="modal">Cancel</button>
        <button class="btn btn-primary" onclick="SubmitRating(this)">Save Rating</button>
    </div>
</div></div></div>

@section PageScripts {
    <script src="~/assets/static/plugins/DataTables/media/js/jquery.dataTables.js"></script>
    <script src="~/assets/static/plugins/DataTables/media/js/dataTables.bootstrap.min.js"></script>
    <script src="~/assets/static/js/appraisal-review.js"></script>
}
